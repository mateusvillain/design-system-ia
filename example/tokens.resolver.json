{
  "name": "Design System",
  "version": "2025.10",
  "sets": {
    "primitive": {
      "sources": [
        { "$ref": "tokens/semantic/semantic.json" }
      ]
    }
  },
  "modifiers": {
    "size": {
      "default": "desktop",
      "contexts": {
        "mobile": [
          { "$ref": "tokens/primitive/spacing/spacing.small.json" }
        ],
        "desktop": [
          { "$ref": "tokens/primitive/spacing/spacing.large.json" }
        ]
      }
    },
    "brandTheme": {
      "default": "brand-a-light",
      "contexts": {
        "brand-a-light": [
          { "$ref": "tokens/primitive/theme/brand-a/light.json" }
        ],
        "brand-a-dark": [
          { "$ref": "tokens/primitive/theme/brand-a/dark.json" }
        ],
        "brand-b-light": [
          { "$ref": "tokens/primitive/theme/brand-b/light.json" }
        ],
        "brand-b-dark": [
          { "$ref": "tokens/primitive/theme/brand-b/dark.json" }
        ]
      }
    }
  },
  "resolutionOrder": [
    { "$ref": "#/sets/primitive" },
    { "$ref": "#/modifiers/size" },
    { "$ref": "#/modifiers/brandTheme" }
  ]
}
