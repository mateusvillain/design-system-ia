{
  "font-family": {
    "$type": "fontFamily",
    "sans": {
      "$value": [
        "Nunito Sans",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ]
    },
    "brand": {
      "$value": [
        "Avenir Next",
        "Nunito Sans",
        "Helvetica Neue",
        "Arial",
        "sans-serif"
      ]
    }
  },
  "font-weight": {
    "$type": "fontWeight",
    "regular": {
      "$value": 400
    },
    "medium": {
      "$value": 600
    },
    "bold": {
      "$value": 700
    },
    "black": {
      "$value": 800
    }
  },
  "line-height": {
    "$type": "number",
    "tight": {
      "$value": 1.1
    },
    "normal": {
      "$value": 1.5
    },
    "relaxed": {
      "$value": 1.7
    }
  },
  "letter-spacing": {
    "$type": "dimension",
    "tight": {
      "$value": {
        "value": -0.02,
        "unit": "em"
      }
    },
    "normal": {
      "$value": {
        "value": 0,
        "unit": "em"
      }
    },
    "wide": {
      "$value": {
        "value": 0.04,
        "unit": "em"
      }
    }
  }
}
